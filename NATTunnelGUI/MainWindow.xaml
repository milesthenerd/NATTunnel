<Window x:Class="NATTunnelGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NATTunnel"
        Height="500"
        Width="800"
        Background="{StaticResource ContentBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="CopyableValue"
               TargetType="TextBox">
            <Setter Property="IsReadOnly"
                    Value="True"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="0"/>
            <Setter Property="Margin"
                    Value="0,0,0,12"/>
            <Setter Property="IsTabStop"
                    Value="False"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Command="ApplicationCommands.Copy"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0"
                Grid.RowSpan="3"
                Background="{StaticResource SidebarBrush}">
            <StackPanel Margin="12">
                <!-- Connection Status -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,16">
                    <Ellipse x:Name="StatusDot"
                             Width="10"
                             Height="10"
                             Fill="{StaticResource StatusRedBrush}"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText"
                               Text="Connecting..."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="8,0,0,0"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Network Name -->
                <TextBlock Text="NETWORK"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="NetworkNameText"
                         Text="-"
                         Foreground="{StaticResource AccentBlueBrush}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Style="{StaticResource CopyableValue}"/>

                <!-- Mesh IP -->
                <TextBlock Text="MESH IP"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="MeshIPText"
                         Text="-"
                         Foreground="{StaticResource AccentTealBrush}"
                         FontSize="13"
                         FontFamily="Consolas"
                         Style="{StaticResource CopyableValue}"/>

                <!-- Peer ID -->
                <TextBlock Text="PEER ID"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="PeerIDText"
                         Text="-"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="11"
                         FontFamily="Consolas"
                         Style="{StaticResource CopyableValue}"/>

                <!-- NAT Type -->
                <TextBlock Text="NAT TYPE"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="NATTypeText"
                         Text="-"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="12"
                         Style="{StaticResource CopyableValue}"/>

                <!-- Introducer -->
                <TextBlock Text="ROLE"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="RoleText"
                         Text="-"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="12"
                         Style="{StaticResource CopyableValue}"/>

                <!-- Introducer Mesh IP -->
                <TextBlock x:Name="IntroducerLabel"
                           Text="INTRODUCER"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="0,0,0,4"
                           Visibility="Collapsed"/>
                <TextBox x:Name="IntroducerText"
                         Text="-"
                         Foreground="{StaticResource AccentTealBrush}"
                         FontSize="11"
                         FontFamily="Consolas"
                         Style="{StaticResource CopyableValue}"
                         Visibility="Collapsed"/>

                <!-- Uptime -->
                <TextBlock Text="UPTIME"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="UptimeText"
                         Text="-"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         FontSize="12"
                         Style="{StaticResource CopyableValue}"
                         Margin="0"/>
            </StackPanel>
        </Border>

        <!-- Vertical Separator -->
        <Border Grid.Column="1"
                Grid.RowSpan="3"
                Background="{StaticResource BorderBrush}"/>

        <!-- Main Content: Peer List -->
        <DockPanel Grid.Column="2"
                   Grid.Row="0">
            <!-- Header -->
            <Border DockPanel.Dock="Top"
                    Padding="12,8">
                <DockPanel>
                    <TextBlock x:Name="PeerCountHeader"
                               Text="Peers (0)"
                               Foreground="{StaticResource AccentBlueBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                </DockPanel>
            </Border>

            <!-- Peer ListView -->
            <ListView x:Name="PeerListView"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      FontSize="12"
                      FontFamily="Consolas">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background"
                                        Value="#2D2D30"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="BorderThickness"
                                        Value="0"/>
                                <Setter Property="Padding"
                                        Value="8,4"/>
                                <Setter Property="FontSize"
                                        Value="11"/>
                                <Setter Property="FontWeight"
                                        Value="Bold"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="Mesh IP"
                                        Width="110"
                                        DisplayMemberBinding="{Binding MeshIP}"/>
                        <GridViewColumn Header="Peer ID"
                                        Width="90"
                                        DisplayMemberBinding="{Binding PeerIDShort}"/>
                        <GridViewColumn Header="NAT"
                                        Width="80"
                                        DisplayMemberBinding="{Binding NATType}"/>
                        <GridViewColumn Header="Endpoint"
                                        Width="140"
                                        DisplayMemberBinding="{Binding Endpoint}"/>
                        <GridViewColumn Header="Latency"
                                        Width="60"
                                        DisplayMemberBinding="{Binding LatencyDisplay}"/>
                        <GridViewColumn Header="Status"
                                        Width="80"
                                        DisplayMemberBinding="{Binding StatusDisplay}"/>
                    </GridView>
                </ListView.View>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Padding"
                                Value="0,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="{StaticResource ListItemHoverBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </DockPanel>

        <!-- Horizontal Separator -->
        <Border Grid.Column="2"
                Grid.Row="1"
                Background="{StaticResource BorderBrush}"/>

        <!-- Log Panel -->
        <TextBox x:Name="LogTextBox"
                 Grid.Column="0"
                 Grid.ColumnSpan="3"
                 Grid.Row="2"
                 IsReadOnly="True"
                 Background="#1A1A1A"
                 Foreground="{StaticResource TextSecondaryBrush}"
                 FontFamily="Consolas"
                 FontSize="11"
                 BorderThickness="0"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 Padding="8,4"/>
    </Grid>
</Window>
