<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NATTunnelGUI.FirewallWindow"
        Title="Firewall"
        Height="560"
        Width="720"
        Background="{StaticResource ContentBrush}"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock.section-header">
            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.hint">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontStyle" Value="Italic" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Styles>

    <Grid Margin="16" RowDefinitions="Auto,*">

        <!-- Own fingerprint header -->
        <Border Grid.Row="0"
                Background="#1E1E1E"
                BorderBrush="{StaticResource BorderBrushStatic}"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="YOUR FINGERPRINT" Classes="section-header" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBox x:Name="OwnFingerprintText"
                             Text="-"
                             IsReadOnly="True"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             FontFamily="Consolas,Menlo,monospace"
                             FontSize="16"
                             Foreground="{StaticResource AccentTealBrush}"
                             VerticalAlignment="Center" />
                    <Button x:Name="CopyFingerprintButton"
                            Content="Copy"
                            Classes="action"
                            Click="CopyFingerprint_Click"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Share this with peers who want to allow or block you."
                           Classes="hint" />
            </StackPanel>
        </Border>

        <!-- Two-column list area -->
        <Grid Grid.Row="1" ColumnDefinitions="*,12,*">

            <!-- Known peers -->
            <Border Grid.Column="0"
                    Background="#1E1E1E"
                    BorderBrush="{StaticResource BorderBrushStatic}"
                    BorderThickness="1"
                    Padding="12">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" x:Name="KnownPeersHeader"
                               Text="KNOWN PEERS"
                               Classes="section-header" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="KnownPeersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,6"
                                            BorderBrush="{StaticResource BorderBrushStatic}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding MeshIP}"
                                                           Foreground="{StaticResource AccentTealBrush}"
                                                           FontFamily="Consolas,Menlo,monospace"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding FingerprintDisplay}"
                                                           Foreground="{Binding FingerprintForeground}"
                                                           FontFamily="Consolas,Menlo,monospace"
                                                           FontSize="10"
                                                           Margin="0,1,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Block"
                                                    Classes="action"
                                                    Click="BlockPeer_Click"
                                                    Tag="{Binding Fingerprint}"
                                                    IsEnabled="{Binding CanBlock}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Blocked list -->
            <Border Grid.Column="2"
                    Background="#1E1E1E"
                    BorderBrush="{StaticResource BorderBrushStatic}"
                    BorderThickness="1"
                    Padding="12">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" x:Name="BlockedHeader"
                               Text="BLOCKED (0)"
                               Classes="section-header" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="BlockedList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,6"
                                            BorderBrush="{StaticResource BorderBrushStatic}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Fingerprint}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontFamily="Consolas,Menlo,monospace"
                                                       FontSize="13"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Content="Unblock"
                                                    Classes="action"
                                                    Click="UnblockPeer_Click"
                                                    Tag="{Binding Fingerprint}"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
