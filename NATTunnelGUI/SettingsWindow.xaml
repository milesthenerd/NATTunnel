<Window x:Class="NATTunnelGUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="560"
        Width="420"
        Background="{StaticResource ContentBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SettingLabel"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"
                    Value="11"/>
            <Setter Property="Margin"
                    Value="0,8,0,3"/>
        </Style>
        <Style x:Key="SettingInput"
               TargetType="TextBox">
            <Setter Property="Background"
                    Value="#1E1E1E"/>
            <Setter Property="Foreground"
                    Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="6,4"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="FontFamily"
                    Value="Consolas"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Network Settings -->
                <TextBlock Text="NETWORK"
                           Foreground="{StaticResource AccentBlueBrush}"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="0,0,0,2"/>
                <TextBlock Text="Changes require reconnect"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontStyle="Italic"
                           Margin="0,0,0,4"/>

                <TextBlock Text="Mediation Server"
                           Style="{StaticResource SettingLabel}"/>
                <TextBox x:Name="MediationEndpointBox"
                         Style="{StaticResource SettingInput}"/>

                <TextBlock Text="Network ID"
                           Style="{StaticResource SettingLabel}"/>
                <TextBox x:Name="NetworkIDBox"
                         Style="{StaticResource SettingInput}"/>

                <TextBlock Text="Network Secret"
                           Style="{StaticResource SettingLabel}"/>
                <PasswordBox x:Name="NetworkSecretBox"
                             Background="#2D2D30" Foreground="White"
                             BorderBrush="#3F3F46" BorderThickness="1"
                             Padding="4" Margin="0,0,0,8"/>

                <TextBlock Text="Mesh Subnet Prefix"
                           Style="{StaticResource SettingLabel}"/>
                <TextBox x:Name="MeshSubnetBox"
                         Style="{StaticResource SettingInput}"/>

                <!-- Separator -->
                <Border Height="1"
                        Background="{StaticResource BorderBrush}"
                        Margin="0,14,0,8"/>

                <!-- Timing Settings -->
                <TextBlock Text="TIMING"
                           Foreground="{StaticResource AccentBlueBrush}"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="0,0,0,2"/>
                <TextBlock Text="Applied immediately (no reconnect needed)"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           FontStyle="Italic"
                           Margin="0,0,0,4"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="30"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Heartbeat Interval"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             x:Name="HeartbeatBox"
                             Style="{StaticResource SettingInput}"
                             Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="sec"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                    <TextBlock Grid.Row="1"
                               Text="Probe Interval"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             x:Name="ProbeBox"
                             Style="{StaticResource SettingInput}"
                             Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="1"
                               Grid.Column="2"
                               Text="sec"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                    <TextBlock Grid.Row="2"
                               Text="Stale Timeout"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             x:Name="StaleTimeoutBox"
                             Style="{StaticResource SettingInput}"
                             Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Text="sec"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                    <TextBlock Grid.Row="3"
                               Text="Repair Cooldown"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3"
                             Grid.Column="1"
                             x:Name="RepairCooldownBox"
                             Style="{StaticResource SettingInput}"
                             Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="3"
                               Grid.Column="2"
                               Text="sec"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                    <TextBlock Grid.Row="4"
                               Text="Dead Threshold Ack Count"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4"
                             Grid.Column="1"
                             x:Name="DeadThresholdBox"
                             Style="{StaticResource SettingInput}"
                             Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="4"
                               Grid.Column="2"
                               Text=""
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                    <TextBlock Grid.Row="5"
                               Text="Grace Period"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5"
                             Grid.Column="1"
                             x:Name="GracePeriodBox"
                             Style="{StaticResource SettingInput}"
                             Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="5"
                               Grid.Column="2"
                               Text="sec"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                    <TextBlock Grid.Row="6"
                               Text="Grace Period (Sym.)"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="6"
                             Grid.Column="1"
                             x:Name="GracePeriodSymBox"
                             Style="{StaticResource SettingInput}"
                             Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="6"
                               Grid.Column="2"
                               Text="sec"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>

                    <TextBlock Grid.Row="7"
                               Text="Isolation Grace Period"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="7"
                             Grid.Column="1"
                             x:Name="IsolationGraceBox"
                             Style="{StaticResource SettingInput}"
                             Margin="0,4,0,0"/>
                    <TextBlock Grid.Row="7"
                               Grid.Column="2"
                               Text="sec"
                               Style="{StaticResource SettingLabel}"
                               VerticalAlignment="Center"
                               Margin="6,0,0,0"/>
                </Grid>

                <!-- Separator -->
                <Border Height="1"
                        Background="{StaticResource BorderBrush}"
                        Margin="0,14,0,8"/>

                <!-- Peer ID (read-only) -->
                <TextBlock Text="PEER ID (auto-generated)"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10"
                           Margin="0,0,0,3"/>
                <TextBox x:Name="PeerIDBox"
                         IsReadOnly="True"
                         Background="#1A1A1A"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         Padding="6,4"
                         FontSize="11"
                         FontFamily="Consolas"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Click="Cancel_Click"
                    Width="80"
                    Height="30"
                    Background="#3E3E42"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    FontSize="12"
                    Cursor="Hand"/>
            <Button Content="Save"
                    Click="Save_Click"
                    Width="80"
                    Height="30"
                    Margin="8,0,0,0"
                    Background="{StaticResource AccentBlueBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="12"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
