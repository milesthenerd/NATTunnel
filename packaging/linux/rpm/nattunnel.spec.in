Name:           nattunnel
Version:        @VERSION@
Release:        2%{?dist}
Summary:        Mesh VPN daemon and GUI with NAT hole-punching
License:        MIT
URL:            https://github.com/milesthenerd/NATTunnel
BuildArch:      x86_64

Requires:       wireguard-tools
Requires:       iproute
Requires:       libX11
Requires:       libICE
Requires:       libSM
Requires:       fontconfig
Requires:       dotnet-runtime-9.0

# Disable automatic dependency extraction — it tries to pin glibc versions from the bundled
# native shims and ends up wrong.
AutoReqProv:    no

%description
NATTunnel creates WireGuard tunnels between peers behind NAT, using a
mediation server to coordinate UDP hole-punching. Peers form a fully
decentralized mesh where every peer can reach every other peer.

Includes the systemd-managed daemon (nattunneld) and a desktop GUI
(nattunnel-gui) that attaches to the running daemon.

%install
# Files are staged into %{buildroot} by build.sh before rpmbuild runs.

%files
%attr(0755, root, root) /usr/bin/nattunneld
%attr(0755, root, root) /usr/bin/nattunnel-gui
/usr/lib/nattunnel
/usr/lib/nattunnel-gui
%attr(0644, root, root) /usr/share/applications/nattunnel.desktop
%attr(0644, root, root) /lib/systemd/system/nattunnel.service

%post
systemctl daemon-reload >/dev/null 2>&1 || :
systemctl enable --now nattunnel.service >/dev/null 2>&1 || :

%preun
if [ $1 -eq 0 ]; then
    systemctl --no-reload disable --now nattunnel.service >/dev/null 2>&1 || :
fi

%postun
systemctl daemon-reload >/dev/null 2>&1 || :
if [ $1 -eq 0 ]; then
    rm -rf /etc/nattunnel
fi

%changelog
* Thu May 15 2026 NATTunnel maintainers (milesthenerd) - @VERSION@-2
- Update deps and license

* Thu May 15 2026 NATTunnel maintainers (milesthenerd) - @VERSION@-1
- Initial RPM package.
